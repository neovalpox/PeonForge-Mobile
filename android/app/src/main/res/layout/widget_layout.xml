<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#16120a"
    android:padding="8dp"
    android:gravity="center_vertical">

    <!-- Character avatar -->
    <ImageView
        android:id="@+id/widget_avatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@mipmap/ic_launcher"
        android:scaleType="centerCrop"
        android:contentDescription="Avatar" />

    <!-- Stats column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="4dp">

        <!-- Level row -->
        <TextView
            android:id="@+id/widget_level"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Niveau 1"
            android:textColor="#dfbd5e"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- XP progress bar -->
        <ProgressBar
            android:id="@+id/widget_xp_bar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress_bar" />

        <!-- Tasks + Steps row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_tasks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 taches"
                android:textColor="#c8b88a"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_steps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 pas"
                android:textColor="#c8b88a"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/widget_happiness"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50%"
                android:textColor="#dfbd5e"
                android:textSize="11sp"
                android:drawablePadding="2dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
